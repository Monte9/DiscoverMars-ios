# fastlane environment template.
#
# Setup:
#   1. Copy this file to `fastlane/.env`  (git-ignored — never commit it).
#        cp fastlane/.env.example fastlane/.env
#   2. Fill in your own values below.
#
# fastlane automatically loads fastlane/.env.

# Apple ID email used for App Store Connect / TestFlight uploads.
FASTLANE_APPLE_ID=you@example.com

# Git URL of your fastlane match certificates repo (keep this repo PRIVATE).
MATCH_GIT_URL=git@github.com:your-org/your-certificates-repo.git

# Passphrase used by fastlane match to encrypt/decrypt the certificates repo.
# Use a strong, unique value — do NOT reuse the old one.
MATCH_PASSWORD=change-me
