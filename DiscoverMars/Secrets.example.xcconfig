// Secrets.example.xcconfig — template (safe to commit, contains no real keys).
//
// Setup:
//   1. Copy this file to `Secrets.xcconfig` in the same folder.
//        cp DiscoverMars/Secrets.example.xcconfig DiscoverMars/Secrets.xcconfig
//   2. Replace the placeholder values below with your own keys.
//   3. Build & run. `Secrets.xcconfig` is git-ignored so your keys stay private.
//
// These values are injected into Info.plist at build time and read at runtime
// via AppSecrets (see DiscoverMars/Managers/RequestPath.swift).

// NASA API key — get a free one at https://api.nasa.gov
NASA_API_KEY = YOUR_NASA_API_KEY_HERE

// Mixpanel project token — Mixpanel dashboard -> Settings -> Project Settings
MIXPANEL_TOKEN = YOUR_MIXPANEL_TOKEN_HERE
